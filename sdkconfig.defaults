# Configuración base del proyecto — persiste tras idf.py fullclean
# Generado para ESP32-WROOM-32 con 4MB de flash

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Tabla de particiones personalizada (ver partitions.csv)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
